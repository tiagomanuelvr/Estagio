          },
          "order": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Order"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Movie": {
        "required": [
          "genre",
          "rating",
          "title"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "maxLength": 60,
            "minLength": 3,
            "type": "string"
          },
          "releaseDate": {
            "type": "string",
            "format": "date"
          },
          "genre": {
            "maxLength": 30,
            "minLength": 0,
            "pattern": "^[A-Z]+[a-zA-Z\\s]*$",
            "type": "string"
          },
          "price": {
            "maximum": 100,
            "minimum": 1,
            "type": "number",
            "format": "currency"
          },
          "rating": {
            "maxLength": 5,
            "minLength": 0,
            "pattern": "^[A-Z]+[a-zA-Z0-9\"'\\s-]*$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "MovieDTO": {
        "required": [
          "genre",
          "rating",
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 60,
            "minLength": 3,
            "type": "string"
          },
          "releaseDate": {
            "type": "string",
            "format": "date"
          },
          "genre": {
            "maxLength": 30,
            "minLength": 0,
            "pattern": "^[A-Z]+[a-zA-Z\\s]*$",
            "type": "string"
          },
          "price": {
            "maximum": 100,
            "minimum": 1,
            "type": "number",
            "format": "currency"
          },
          "rating": {
            "maxLength": 5,
            "minLength": 0,
            "pattern": "^[A-Z]+[a-zA-Z0-9\"'\\s-]*$",
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "MovieDtResult": {
        "type": "object",
        "properties": {
          "draw": {
            "type": "integer",
            "format": "int32"
          },
          "recordsTotal": {
            "type": "integer",
            "format": "int32"
          },
          "recordsFiltered": {
            "type": "integer",
            "format": "int32"
          },
          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Movie"
            },
            "nullable": true
          },
          "error": {
            "type": "string",
            "nullable": true
          },
          "partialView": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Order": {
        "type": "object",
        "properties": {
          "column": {
            "type": "integer",
            "format": "int32"
          },
          "dir": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Search": {
        "type": "object",
        "properties": {
          "value": {
            "type": "string",
            "nullable": true
          },
          "regex": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
