          }
        },
        "additionalProperties": false
      },
      "DataTableAjaxPostModel": {
        "type": "object",
        "properties": {
          "draw": {
            "type": "integer",
            "format": "int32"
          },
          "start": {
            "type": "integer",
            "format": "int32"
          },
          "length": {
            "type": "integer",
            "format": "int32"
          },
          "columns": {
            "type": "array",
            "items": {
