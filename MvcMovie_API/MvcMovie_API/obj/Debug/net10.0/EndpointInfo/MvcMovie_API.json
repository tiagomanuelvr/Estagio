  "components": {
    "schemas": {
      "Column": {
        "type": "object",
        "properties": {
          "data": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "searchable": {
            "type": "boolean"
          },
          "orderable": {
            "type": "boolean"
          },
          "search": {
