@model int

@{
    ViewData["Title"] = "Delete_API";
}

<h1>Delete_API</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Movie</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            Title
        </dt>
        <dd class = "col-sm-10 title"></dd>
        <dt class = "col-sm-2">
            ReleaseDate
        </dt>
        <dd class="col-sm-10 releaseDate"></dd>
        <dt class = "col-sm-2">
            Genre
        </dt>
        <dd class = "col-sm-10 genre"></dd>
        <dt class = "col-sm-2">
            Price
        </dt>
        <dd class = "col-sm-10 price"></dd>
        <dt class="col-sm-2">
            Rating
        </dt>
        <dd class="col-sm-10 rating"></dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" value="@Model" name="id" id="id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index">Back to List</a>
    </form>
</div>

@section Scripts {
    <script src="~/js/delete_ApiMovies.js"></script>
}
